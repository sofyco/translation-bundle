{
    "name": "sofyco/translation-bundle",
    "type": "symfony-bundle",
    "version": "1.0.0",
    "description": "Symfony Translation Bundle",
    "keywords": ["php", "symfony", "translation", "locale", "loader"],
    "homepage": "https://github.com/sofyco/translation-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Sofiia Korzhova",
            "email": "sofykorzhova@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "symfony/framework-bundle": "^8.0",
        "symfony/translation": "^8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.1"
    },
    "autoload": {
        "psr-4": {
            "Sofyco\\Bundle\\TranslationBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sofyco\\Bundle\\TranslationBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true
    }
}
